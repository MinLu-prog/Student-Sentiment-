# Copy this file to .env and fill in your own local values:
#   cp .env.example .env      (macOS/Linux)
#   copy .env.example .env    (Windows)
#
# .env is gitignored on purpose — never commit real secrets.

# Connection string for your local PostgreSQL database. Create the database
# first (e.g. `createdb student_sentiment` or via a GUI like pgAdmin), then
# point this at it. Format: postgresql://<user>:<password>@<host>:<port>/<db>
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/student_sentiment?schema=public"

# Any long random string — used to sign login tokens. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace_with_a_long_random_string"
